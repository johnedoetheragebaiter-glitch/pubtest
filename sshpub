#!/usr/bin/env bash
# =============================================================================
# setup_ssh.sh — Reproducible SSH config setup
# Usage: ./setup_ssh.sh [OPTIONS]
# =============================================================================

set -euo pipefail

# ── Colours ──────────────────────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; BOLD='\033[1m'; RESET='\033[0m'

log()    { echo -e "${GREEN}[✔]${RESET} $*"; }
warn()   { echo -e "${YELLOW}[!]${RESET} $*"; }
error()  { echo -e "${RED}[✘]${RESET} $*" >&2; exit 1; }
header() { echo -e "\n${BOLD}${BLUE}── $* ──${RESET}"; }

# ── Defaults ─────────────────────────────────────────────────────────────────
SSH_DIR="${HOME}/.ssh"
CONFIG_FILE="${SSH_DIR}/config"
PORT=2222
KEY_TYPE="ed25519"           # ed25519 (recommended) or rsa
KEY_BITS=4096                # only used when KEY_TYPE=rsa
BACKUP=true                  # back up existing config before editing
GITHUB_USER=""               # GitHub username — prints curl deploy one-liner
GITHUB_TOKEN=""              # GitHub PAT — auto-uploads public keys via REST API
HARDEN_SERVER=false          # edit /etc/ssh/sshd_config with secure settings

# ── Help ─────────────────────────────────────────────────────────────────────
usage() {
cat <<EOF
${BOLD}setup_ssh.sh${RESET} — Reproducible SSH config setup

${BOLD}USAGE${RESET}
  ./setup_ssh.sh [OPTIONS]

${BOLD}REQUIRED${RESET}
  -n, --host-name   HOST_NAME   Alias used in ssh / git commands  (e.g. my-server)
  -h, --host-addr   HOST_ADDR   Real hostname or IP                (e.g. 192.168.1.10)
  -u, --user        USER_NAME   Remote SSH user                    (e.g. git)

${BOLD}OPTIONAL${RESET}
  -k, --key-file      KEY_FILE   Path to private key  [default: ~/.ssh/id_<type>_<host-name>]
  -p, --port          PORT       SSH port             [default: ${PORT}]
  -t, --key-type      TYPE       ed25519 | rsa        [default: ${KEY_TYPE}]
  -b, --bits          BITS       RSA key bits         [default: ${KEY_BITS}]
      --no-backup                Skip config backup

${BOLD}GITHUB${RESET}
  -g, --github-user   GH_USER    Your GitHub username — generates a curl
                                 one-liner to pull ALL your GH keys onto any
                                 server without toggling password auth
      --github-token  TOKEN      GitHub PAT (classic) with 'write:public_key'
                                 scope — auto-uploads this machine's public
                                 key(s) to GitHub via REST API

${BOLD}SERVER HARDENING${RESET}
      --harden-server            Edit /etc/ssh/sshd_config on THIS machine with
                                 secure settings (requires sudo). Applied settings:
                                   PubkeyAuthentication  yes
                                   PasswordAuthentication no   (keys only)
                                   PermitRootLogin        no
                                   MaxAuthTries           3
                                   LoginGraceTime         30
                                   ClientAliveInterval    60
                                   ClientAliveCountMax    3
                                   X11Forwarding          no
                                 sshd is reloaded live after changes.

      --help                     Show this help

${BOLD}EXAMPLES${RESET}
  # Minimal — key pair is generated automatically
  ./setup_ssh.sh -n myserver -h 203.0.113.5 -u deploy

  # Bring your own key
  ./setup_ssh.sh -n github -h github.com -u git -k ~/.ssh/id_ed25519_github

  # Custom port + RSA key
  ./setup_ssh.sh -n vpn-box -h 10.0.0.1 -u admin -p 22 -t rsa -b 4096
EOF
exit 0
}

# ── Argument parsing ──────────────────────────────────────────────────────────
HOST_NAME=""; HOST_ADDR=""; USER_NAME=""; KEY_FILE=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    -n|--host-name)    HOST_NAME="$2";    shift 2 ;;
    -h|--host-addr)    HOST_ADDR="$2";    shift 2 ;;
    -u|--user)         USER_NAME="$2";    shift 2 ;;
    -k|--key-file)     KEY_FILE="$2";     shift 2 ;;
    -p|--port)         PORT="$2";         shift 2 ;;
    -t|--key-type)     KEY_TYPE="$2";     shift 2 ;;
    -b|--bits)         KEY_BITS="$2";     shift 2 ;;
    -g|--github-user)  GITHUB_USER="$2";  shift 2 ;;
    --github-token)    GITHUB_TOKEN="$2"; shift 2 ;;
    --harden-server)   HARDEN_SERVER=true; shift  ;;
    --no-backup)       BACKUP=false;      shift   ;;
    --help)            usage ;;
    *) error "Unknown option: $1  (run with --help)" ;;
  esac
done

# ── GitHub upload helper ──────────────────────────────────────────────────────
# Usage: gh_upload_key <pubkey_path> <title>
gh_upload_key() {
  local pubkey_path="$1" title="$2"
  [[ -z "$GITHUB_TOKEN" ]] && return 0   # no-op if no token supplied
  local pubkey_content http_status
  pubkey_content="$(cat "$pubkey_path")"
  http_status=$(curl -s -o /tmp/_gh_key_resp.json -w "%{http_code}" \
    -X POST "https://api.github.com/user/keys" \
    -H "Authorization: token ${GITHUB_TOKEN}" \
    -H "Accept: application/vnd.github+json" \
    -H "Content-Type: application/json" \
    -d "{\"title\":\"${title}\",\"key\":\"${pubkey_content}\"}")
  case "$http_status" in
    201) log  "GitHub: key '${title}' uploaded successfully" ;;
    422) warn "GitHub: key '${title}' already exists — skipping" ;;
    401) warn "GitHub: bad token (401) — check your PAT has write:public_key scope" ;;
    *  ) warn "GitHub: unexpected status ${http_status}:"
         cat /tmp/_gh_key_resp.json ;;
  esac
  rm -f /tmp/_gh_key_resp.json
}

# ── sshd_config hardening helper ──────────────────────────────────────────────
# Sets a key=value pair in sshd_config, replacing any existing line (idempotent)
# Usage: sshd_set <directive> <value>
sshd_set() {
  local directive="$1" value="$2" conf="/etc/ssh/sshd_config"
  if grep -qE "^#?[[:space:]]*${directive}[[:space:]]" "$conf" 2>/dev/null; then
    # Replace existing (commented or uncommented) line
    sudo sed -i -E "s|^#?[[:space:]]*${directive}[[:space:]].*|${directive} ${value}|" "$conf"
  else
    # Append if directive not present at all
    echo "${directive} ${value}" | sudo tee -a "$conf" > /dev/null
  fi
}

harden_server() {
  local conf="/etc/ssh/sshd_config"
  header "sshd_config hardening"

  command -v sudo &>/dev/null || { warn "sudo not found — skipping hardening"; return; }
  sudo test -f "$conf" || { warn "${conf} not found — skipping hardening"; return; }

  # ── Backup ──
  local bak="${conf}.bak.$(date +%Y%m%d_%H%M%S)"
  sudo cp "$conf" "$bak"
  log "sshd_config backed up → ${bak}"

  # ── Apply settings ──
  # Key-based auth (the whole point of this script)
  sshd_set "PubkeyAuthentication"    "yes"
  sshd_set "AuthorizedKeysFile"      ".ssh/authorized_keys"

  # Disable password auth — keys only after running this script
  sshd_set "PasswordAuthentication"  "no"
  sshd_set "ChallengeResponseAuthentication" "no"
  sshd_set "KbdInteractiveAuthentication"    "no"

  # Root lockdown
  sshd_set "PermitRootLogin"         "no"
  sshd_set "PermitEmptyPasswords"    "no"

  # Brute-force protection
  sshd_set "MaxAuthTries"            "3"
  sshd_set "MaxSessions"             "5"
  sshd_set "LoginGraceTime"          "30"

  # Session keepalive (matches ~/.ssh/config values set above)
  sshd_set "ClientAliveInterval"     "60"
  sshd_set "ClientAliveCountMax"     "3"
  sshd_set "TCPKeepAlive"            "yes"

  # Attack surface reduction
  sshd_set "X11Forwarding"           "no"
  sshd_set "AllowAgentForwarding"    "yes"   # needed for WireGuard / jump hosts
  sshd_set "PrintMotd"               "no"

  # Use the port specified by -p (default 22 for sshd itself)
  sshd_set "Port"                    "${PORT}"

  log "Settings applied to ${conf}"

  # ── Validate config before reloading ──
  if sudo sshd -t 2>/dev/null; then
    log "Config syntax OK"
    # Reload without dropping connections (graceful)
    if systemctl is-active --quiet ssh 2>/dev/null; then
      sudo systemctl reload ssh   && log "ssh service reloaded"
    elif systemctl is-active --quiet sshd 2>/dev/null; then
      sudo systemctl reload sshd  && log "sshd service reloaded"
    else
      warn "Could not detect running ssh/sshd service — reload manually:"
      warn "  sudo systemctl reload sshd"
    fi
  else
    warn "sshd config syntax error — restoring backup ${bak}"
    sudo cp "$bak" "$conf"
    warn "Backup restored. Review the error above."
  fi
}

# ── Validate required args ────────────────────────────────────────────────────
[[ -z "$HOST_NAME" ]] && error "Missing --host-name"
[[ -z "$HOST_ADDR" ]] && error "Missing --host-addr"
[[ -z "$USER_NAME" ]] && error "Missing --user"
[[ "$KEY_TYPE" =~ ^(ed25519|rsa)$ ]] || error "KEY_TYPE must be ed25519 or rsa"

# Default key path derived from host alias
[[ -z "$KEY_FILE" ]] && KEY_FILE="${SSH_DIR}/id_${KEY_TYPE}_${HOST_NAME}"

# ── Setup ~/.ssh ──────────────────────────────────────────────────────────────
header "SSH directory"
if [[ ! -d "$SSH_DIR" ]]; then
  mkdir -p "$SSH_DIR"
  chmod 700 "$SSH_DIR"
  log "Created ${SSH_DIR}"
else
  log "${SSH_DIR} already exists"
fi

# ── Generate key pair (if needed) ────────────────────────────────────────────
header "Key pair"
if [[ -f "$KEY_FILE" ]]; then
  warn "Key already exists at ${KEY_FILE} — skipping generation"
else
  log "Generating ${KEY_TYPE} key → ${KEY_FILE}"
  if [[ "$KEY_TYPE" == "ed25519" ]]; then
    ssh-keygen -t ed25519 -f "$KEY_FILE" -C "${USER_NAME}@${HOST_NAME}" -N ""
  else
    ssh-keygen -t rsa -b "$KEY_BITS" -f "$KEY_FILE" -C "${USER_NAME}@${HOST_NAME}" -N ""
  fi
  chmod 600 "$KEY_FILE"
  chmod 644 "${KEY_FILE}.pub"
  log "Key pair created"
fi

# Upload remote host key to GitHub if token supplied
gh_upload_key "${KEY_FILE}.pub" "${USER_NAME}@${HOST_NAME}"

# ── Backup existing config ────────────────────────────────────────────────────
header "SSH config"
if [[ -f "$CONFIG_FILE" && "$BACKUP" == true ]]; then
  BACKUP_FILE="${CONFIG_FILE}.bak.$(date +%Y%m%d_%H%M%S)"
  cp "$CONFIG_FILE" "$BACKUP_FILE"
  log "Existing config backed up → ${BACKUP_FILE}"
fi

# ── Check for duplicate Host entry ───────────────────────────────────────────
if [[ -f "$CONFIG_FILE" ]] && grep -qE "^Host[[:space:]]+${HOST_NAME}([[:space:]]|$)" "$CONFIG_FILE"; then
  warn "Host '${HOST_NAME}' already present in ${CONFIG_FILE} — skipping append"
else
  # Ensure newline before new block
  [[ -f "$CONFIG_FILE" && -s "$CONFIG_FILE" ]] && echo "" >> "$CONFIG_FILE"

  cat >> "$CONFIG_FILE" <<EOF
Host ${HOST_NAME}
    HostName ${HOST_ADDR}
    User ${USER_NAME}
    Port ${PORT}
    IdentityFile ${KEY_FILE}
    IdentitiesOnly yes
    AddKeysToAgent yes
    ServerAliveInterval 60
    ServerAliveCountMax 3
EOF
  log "Host block appended to ${CONFIG_FILE}"
fi

chmod 600 "$CONFIG_FILE"

# ── Self-registration — local machine entry ───────────────────────────────────
header "Local machine self-registration"
LOCAL_USER="${USER}"
# hostname -s may not exist on all distros; strip domain manually as fallback
LOCAL_HOST="$(hostname 2>/dev/null | cut -d. -f1)"
LOCAL_HOST="${LOCAL_HOST:-$(uname -n | cut -d. -f1)}"
# Prefer ip route for LAN IP (works on Arch + Debian); fall back to hostname -I
LOCAL_IP="$(ip route get 1.1.1.1 2>/dev/null | awk '/src/{for(i=1;i<=NF;i++) if($i=="src") print $(i+1)}' | head -1)"
LOCAL_IP="${LOCAL_IP:-$(hostname -I 2>/dev/null | awk '{print $1}')}"
LOCAL_IP="${LOCAL_IP:-127.0.0.1}"
LOCAL_KEY="${SSH_DIR}/id_${KEY_TYPE}_${LOCAL_HOST}"

log "Detected: user=${LOCAL_USER}  host=${LOCAL_HOST}  ip=${LOCAL_IP}"

# Generate a local identity key if one doesn't exist
if [[ -f "$LOCAL_KEY" ]]; then
  warn "Local key already exists at ${LOCAL_KEY} — skipping"
else
  log "Generating local ${KEY_TYPE} identity key → ${LOCAL_KEY}"
  if [[ "$KEY_TYPE" == "ed25519" ]]; then
    ssh-keygen -t ed25519 -f "$LOCAL_KEY" -C "${LOCAL_USER}@${LOCAL_HOST}" -N ""
  else
    ssh-keygen -t rsa -b "$KEY_BITS" -f "$LOCAL_KEY" -C "${LOCAL_USER}@${LOCAL_HOST}" -N ""
  fi
  chmod 600 "$LOCAL_KEY"
  chmod 644 "${LOCAL_KEY}.pub"
  log "Local key pair created"
fi

# Upload local machine key to GitHub if token supplied
gh_upload_key "${LOCAL_KEY}.pub" "${LOCAL_USER}@${LOCAL_HOST}"

# Write a Host block for this machine (idempotent)
if grep -qE "^Host[[:space:]]+${LOCAL_HOST}([[:space:]]|$)" "$CONFIG_FILE" 2>/dev/null; then
  warn "Host '${LOCAL_HOST}' already in ${CONFIG_FILE} — skipping"
else
  [[ -s "$CONFIG_FILE" ]] && echo "" >> "$CONFIG_FILE"
  # Build heredoc with pre-resolved variable to avoid expansion issues
  SELF_IP="$LOCAL_IP"
  cat >> "$CONFIG_FILE" <<EOF
Host ${LOCAL_HOST}
    HostName ${SELF_IP}
    User ${LOCAL_USER}
    Port 22
    IdentityFile ~/.ssh/id_${KEY_TYPE}_${LOCAL_HOST}
    IdentitiesOnly yes
    AddKeysToAgent yes
    ServerAliveInterval 60
    ServerAliveCountMax 3
EOF
  log "Local host block '${LOCAL_HOST}' appended to ${CONFIG_FILE}"
fi

# ── Print public key for deployment ──────────────────────────────────────────
header "Public key — add this to the server's authorized_keys"
echo -e "${YELLOW}"
cat "${KEY_FILE}.pub"
echo -e "${RESET}"
# ── Quick-copy hints ──────────────────────────────────────────────────────────
header "Next steps"
if [[ -n "$GITHUB_USER" ]]; then
  echo -e "  1. ${BOLD}Deploy ALL your GitHub keys to the server (no password auth toggling):${RESET}"

  echo -e "     Run this ONCE on the server to import every key you have on GitHub:"
  echo -e "     ${YELLOW}ssh ${USER_NAME}@${HOST_ADDR} -p ${PORT} \"curl -fsSL https://github.com/${GITHUB_USER}.keys >> ~/.ssh/authorized_keys\"${RESET}\n"
  echo -e "     Or if password auth is already off, copy the one-liner manually:"
  echo -e "     ${YELLOW}curl -fsSL https://github.com/${GITHUB_USER}.keys >> ~/.ssh/authorized_keys${RESET}\n"
else
  echo -e "  1. Copy the public key to the server:"
  echo -e "     ${BOLD}ssh-copy-id -i ${KEY_FILE}.pub -p ${PORT} ${USER_NAME}@${HOST_ADDR}${RESET}"
  echo -e "     Tip: pass -g/--github-user YOUR_GH_USERNAME to get a smarter deploy one-liner.\n"
fi
echo -e "  2. Test the connection:"
echo -e "     ${BOLD}ssh ${HOST_NAME}${RESET}\n"
echo -e "  3. For Git remotes, use the host alias directly:"
echo -e "     ${BOLD}git remote set-url origin ${USER_NAME}@${HOST_NAME}:<repo>.git${RESET}\n"
echo -e "  4. To re-run on another machine, copy this script and call it with the same flags."

# ── Repeatable config block ───────────────────────────────────────────────────
# Use ~/ so the path is portable regardless of username on the target machine
KEY_FILE_RELATIVE="~/.ssh/$(basename "$KEY_FILE")"

header "Copy-paste this block into ~/.ssh/config on any other machine"
echo -e "${YELLOW}"
cat <<EOF
Host ${HOST_NAME}
    HostName ${HOST_ADDR}
    User ${USER_NAME}
    Port ${PORT}
    IdentityFile ${KEY_FILE_RELATIVE}
    IdentitiesOnly yes
    AddKeysToAgent yes
    ServerAliveInterval 60
    ServerAliveCountMax 3
EOF
echo -e "${RESET}"

# ── Key sharing options ───────────────────────────────────────────────────────
header "Sharing keys across machines"
echo -e "  ${BOLD}Strategy A — each machine has its own key (recommended):${RESET}"
echo -e "  Run this script on each machine. Then copy each machine's public key to the server:"
echo -e "     ${BOLD}ssh-copy-id -i ${KEY_FILE}.pub -p ${PORT} ${USER_NAME}@${HOST_ADDR}${RESET}\n"
echo -e "  ${BOLD}Strategy B — share one key pair across all machines:${RESET}"
echo -e "  Copy the private + public key to the other machine (replace OTHER_HOST):" 
echo -e "     ${BOLD}scp ${KEY_FILE} ${KEY_FILE}.pub OTHER_HOST:~/.ssh/${RESET}"
echo -e "  Then paste the config block above into ~/.ssh/config on that machine.\n"

log "Done."
